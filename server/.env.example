# ─── Kaizen · variables de entorno ──────────────────────────────────────
# Copia este archivo a .env y completa los valores (los entrega FinZen).
# NUNCA commitees el .env real.

# Puerto del server (local)
PORT=4000

# ── FinZen Agent API ──
FINZEN_API_URL=https://finzenai-backend-production.up.railway.app
# Opcional en dev: sin esto el server arranca igual y la web se puede ver;
# las tools que llaman a FinZen (get_kpis, evaluate_segment, ...) van a fallar
# con 401 recién cuando de verdad se usen. Requerida para producción.
FINZEN_AGENT_KEY=

# ── Anthropic / Claude ──
# Opcional en dev: sin esto el server arranca y la web/login funcionan, pero
# mandar un mensaje de chat da un error claro ("falta la key de Anthropic")
# en vez de una respuesta real. Requerida para producción.
ANTHROPIC_API_KEY=

# ── Google Drive · Cerebro y Contenidos (Fase 1) ──
# Credenciales de la Service Account — usa UNA de las dos opciones:
#  - Local: ruta al JSON descargado (el archivo NO se commitea)
#  - Railway: el contenido del JSON codificado en base64
GOOGLE_SERVICE_ACCOUNT_PATH=
GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=
DRIVE_CEREBRO_FOLDER_ID=
DRIVE_CONTENIDOS_FOLDER_ID=

# ── Base de datos propia de Kaizen (requerida: conversaciones, propuestas, audit log) ──
# Postgres. Local recomendado vía Docker o server/prisma/local/setup_mysql.sql
# como alternativa (ver server/prisma/local/README.md para las salvedades).
DATABASE_URL=

# ── Auth del chat de socios (requerida) ──
# Cualquier string largo y aleatorio; nunca lo reutilices de otro proyecto.
JWT_SECRET=

# ── Guardarraíl de campañas (opcional, default 5) ──
KAIZEN_MAX_DRAFTS_PER_DAY=5

# ── Kill switch propio: false = el agente no corre ──
AGENT_ENABLED=true

# ── Cookie de sesión Secure en producción (Railway u otro no siempre lo setea
#    solo) — sin esto en "production", la cookie del login no lleva Secure. ──
NODE_ENV=development

# ── Solo para `npm run chat` (scripts/chatCli.ts), no la usa el server. ──
# A qué Kaizen le habla el cliente de consola. Default: http://localhost:4000
KAIZEN_BASE_URL=
