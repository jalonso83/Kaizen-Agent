# ─── Kaizen · variables de entorno ──────────────────────────────────────
# Copia este archivo a .env y completa los valores (los entrega FinZen).
# NUNCA commitees el .env real.

# Puerto del server (local)
PORT=4000

# ── FinZen Agent API (requeridas) ──
FINZEN_API_URL=https://finzenai-backend-production.up.railway.app
FINZEN_AGENT_KEY=

# ── Anthropic / Claude (requerida) ──
ANTHROPIC_API_KEY=

# ── Google Drive · Cerebro y Contenidos (Fase 1) ──
# Ruta al JSON de la Service Account (el archivo NO se commitea)
GOOGLE_SERVICE_ACCOUNT_PATH=
DRIVE_CEREBRO_FOLDER_ID=
DRIVE_CONTENIDOS_FOLDER_ID=

# ── Base de datos propia de Kaizen (Fase 1: conversaciones, propuestas, audit log) ──
DATABASE_URL=

# ── Auth del chat de socios (Fase 1) ──
JWT_SECRET=

# ── Kill switch propio: false = el agente no corre ──
AGENT_ENABLED=true
